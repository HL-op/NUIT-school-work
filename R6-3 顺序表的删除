#include <stdio.h>
#define N 10

int del(int a[],int *n,int x);

int main()
{
    int a[N],n,i,x,flag;
    scanf("%d",&n);
    for(i=0;i<n;i++)
        scanf("%d",&a[i]);
    scanf("%d",&x);
    flag=del(a,&n,x);
    if(flag)
    {
        for(i=0;i<n;i++)
            printf("%d ",a[i]);
    }
    else
        printf("no %d",x);
    return 0;
}

/* 请在这里填写答案 */
int del(int a[],int *n,int x){

    if(*n<=0){
        return 0;
    }  
    int pos=-1;
    for(int i=0;i<*n;i++){
        if(a[i]==x){
            pos=i;
            break;
        }
    }
    if( pos==-1){
        return 0;
    }
    for(int i=pos;i<(*n-1);i++){

        a[i]=a[i+1];
    }
    (*n)--;
    return 1;
}
